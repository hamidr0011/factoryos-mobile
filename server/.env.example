NODE_ENV=production
PORT=10000

# Supabase project values.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only secret. Never put this in Expo, GitHub, or EXPO_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowed origins. Use * while testing mobile clients.
CORS_ORIGIN=*
